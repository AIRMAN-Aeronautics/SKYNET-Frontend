# =============================================================================
# SKYNET FRONTEND - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in values before starting the app
# All variables MUST be prefixed with VITE_ to be exposed to the browser

# ── API Configuration ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api
VITE_WS_URL=http://localhost:3001

# ── App Configuration ─────────────────────────────────────────────────────────
VITE_APP_NAME=Skynet Academy
VITE_APP_ENV=development

# ── Feature Flags ─────────────────────────────────────────────────────────────
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_REAL_TIME=true
